<section class="section section--dark">
  <div class="container">
    <div class="apex-cta-banner">
      <span class="apex-section-label">{{ section.settings.label | default: 'Limited Time Offer' }}</span>
      <h2 class="apex-cta-banner__title">{{ section.settings.heading | default: 'Ready to Transform Your Marketing?' }}</h2>
      <p class="apex-cta-banner__text">{{ section.settings.text | default: 'Join thousands of entrepreneurs who have already mastered digital marketing with our proven course system.' }}</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        {% if section.settings.btn_primary_label != blank %}
          <a href="{{ section.settings.btn_primary_url }}" class="button button--primary">{{ section.settings.btn_primary_label }}</a>
        {% endif %}
        {% if section.settings.btn_secondary_label != blank %}
          <a href="{{ section.settings.btn_secondary_url }}" class="button button--secondary">{{ section.settings.btn_secondary_label }}</a>
        {% endif %}
      </div>
      {% if section.settings.guarantee != blank %}
        <p style="margin-top:1.5rem; font-size:0.8rem; color:var(--apex-gray-mid);">{{ section.settings.guarantee }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Apex CTA Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {"type": "text", "id": "label", "label": "Label", "default": "Limited Time Offer"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Ready to Transform Your Marketing?"},
    {"type": "textarea", "id": "text", "label": "Description", "default": "Join thousands of entrepreneurs who have already mastered digital marketing with our proven course system."},
    {"type": "text", "id": "btn_primary_label", "label": "Primary button label", "default": "Enroll Now"},
    {"type": "url", "id": "btn_primary_url", "label": "Primary button URL"},
    {"type": "text", "id": "btn_secondary_label", "label": "Secondary button label", "default": "View All Courses"},
    {"type": "url", "id": "btn_secondary_url", "label": "Secondary button URL"},
    {"type": "text", "id": "guarantee", "label": "Guarantee text", "default": "30-day money-back guarantee. No questions asked."}
  ],
  "presets": [{"name": "Apex CTA Banner"}]
}
{% endschema %}
